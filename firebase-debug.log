[debug] [2026-04-05T21:23:04.502Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/couple-organizer-8b245/rulesets {"name":"projects/couple-organizer-8b245/rulesets/7ebf8aee-6f4c-4103-9583-53dee871f87a","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isSelf(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    function isCoupleMember(coupleId) {\n      return signedIn()\n        && exists(/databases/$(database)/documents/couples/$(coupleId))\n        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberIds;\n    }\n\n    match /users/{userId} {\n      allow create, read, update: if isSelf(userId);\n    }\n\n    match /couples/{coupleId} {\n      // Read is open to authenticated users because the current join flow\n      // looks up a couple by inviteCode before the user becomes a member.\n      allow read: if signedIn();\n\n      allow create: if signedIn()\n        && request.resource.data.memberIds is list\n        && request.resource.data.memberIds.size() == 1\n        && request.resource.data.memberIds[0] == request.auth.uid\n        && request.resource.data.memberNames[request.auth.uid] is string\n        && request.resource.data.inviteCode is string;\n\n      allow update: if signedIn()\n        && request.resource.data.memberIds is list\n        && request.resource.data.memberIds.size() <= 2\n        && request.auth.uid in request.resource.data.memberIds;\n    }\n\n    match /todos/{todoId} {\n      allow read: if isCoupleMember(resource.data.coupleId);\n      allow create: if signedIn()\n        && request.resource.data.createdBy == request.auth.uid\n        && isCoupleMember(request.resource.data.coupleId);\n      allow update, delete: if isCoupleMember(resource.data.coupleId);\n    }\n\n    match /shoppingItems/{itemId} {\n      allow read: if isCoupleMember(resource.data.coupleId);\n      allow create: if signedIn()\n        && request.resource.data.addedBy == request.auth.uid\n        && isCoupleMember(request.resource.data.coupleId);\n      allow update, delete: if isCoupleMember(resource.data.coupleId);\n    }\n\n    match /shoppingLists/{listId} {\n      allow read: if isCoupleMember(resource.data.coupleId);\n      allow create: if signedIn()\n        && request.resource.data.createdBy == request.auth.uid\n        && isCoupleMember(request.resource.data.coupleId);\n      allow update, delete: if isCoupleMember(resource.data.coupleId);\n    }\n\n    match /recipes/{recipeId} {\n      allow read: if isCoupleMember(resource.data.coupleId);\n      allow create: if signedIn()\n        && request.resource.data.createdBy == request.auth.uid\n        && isCoupleMember(request.resource.data.coupleId);\n      allow update, delete: if isCoupleMember(resource.data.coupleId);\n    }\n\n    match /mealPlans/{planId} {\n      allow read: if isCoupleMember(resource.data.coupleId);\n      allow create: if signedIn()\n        && request.resource.data.createdBy == request.auth.uid\n        && isCoupleMember(request.resource.data.coupleId);\n      allow update, delete: if isCoupleMember(resource.data.coupleId);\n    }\n\n    match /expenses/{expenseId} {\n      allow read: if isCoupleMember(resource.data.coupleId);\n      allow create: if signedIn()\n        && request.resource.data.createdBy == request.auth.uid\n        && isCoupleMember(request.resource.data.coupleId);\n      allow update, delete: if isCoupleMember(resource.data.coupleId);\n    }\n\n    match /financeEvents/{eventId} {\n      allow read: if isCoupleMember(resource.data.coupleId);\n      allow create: if signedIn()\n        && request.resource.data.createdBy == request.auth.uid\n        && isCoupleMember(request.resource.data.coupleId);\n      allow update, delete: if isCoupleMember(resource.data.coupleId);\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-05T21:23:04.561439Z","metadata":{"services":["cloud.firestore"]}}
