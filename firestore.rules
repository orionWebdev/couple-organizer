rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isCoupleMember(coupleId) {
      return signedIn()
        && exists(/databases/$(database)/documents/couples/$(coupleId))
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberIds;
    }

    match /users/{userId} {
      allow create, read, update: if isSelf(userId);
    }

    match /couples/{coupleId} {
      // Read is open to authenticated users because the current join flow
      // looks up a couple by inviteCode before the user becomes a member.
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && request.resource.data.memberNames[request.auth.uid] is string
        && request.resource.data.inviteCode is string;

      allow update: if signedIn()
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() <= 2
        && request.auth.uid in request.resource.data.memberIds;
    }

    match /todos/{todoId} {
      allow read: if isCoupleMember(resource.data.coupleId);
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isCoupleMember(request.resource.data.coupleId);
      allow update, delete: if isCoupleMember(resource.data.coupleId);
    }

    match /shoppingItems/{itemId} {
      allow read: if isCoupleMember(resource.data.coupleId);
      allow create: if signedIn()
        && request.resource.data.addedBy == request.auth.uid
        && isCoupleMember(request.resource.data.coupleId);
      allow update, delete: if isCoupleMember(resource.data.coupleId);
    }

    match /expenses/{expenseId} {
      allow read: if isCoupleMember(resource.data.coupleId);
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isCoupleMember(request.resource.data.coupleId);
      allow delete: if isCoupleMember(resource.data.coupleId);
    }
  }
}
